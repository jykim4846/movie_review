generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MovieEntry {
  id             String   @id @default(cuid())
  title          String
  watchedAt      DateTime
  watchedPlace   String?
  oneLineReview  String
  detailedReview String?
  instagramDraft String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
