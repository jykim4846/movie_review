generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum WatchMethod {
  THEATER
  OTT
  TV
  DVD
  OTHER
}

enum CaptionTone {
  EMOTIONAL
  WITTY
  CALM
  REVIEW
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  passwordHash String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  movieLogs MovieLog[]

  @@index([createdAt])
}

model Movie {
  id              String     @id @default(cuid())
  externalMovieId String?    @unique
  title           String
  originalTitle   String?
  releaseDate     DateTime?
  posterUrl       String?
  overview        String?
  runtime         Int?
  genres          String[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  movieLogs       MovieLog[]

  @@index([title])
  @@index([releaseDate])
  @@index([createdAt])
}

model MovieLog {
  id                String             @id @default(cuid())
  userId            String
  movieId           String
  watchedAt         DateTime
  watchPlace        String?
  watchMethod       WatchMethod
  companions        String?
  rating            Decimal?           @db.Decimal(2, 1)
  shortReview       String?
  isSpoiler         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie             Movie              @relation(fields: [movieId], references: [id], onDelete: Cascade)
  generatedCaptions GeneratedCaption[]

  @@index([userId, watchedAt(sort: Desc)])
  @@index([movieId, watchedAt(sort: Desc)])
  @@index([watchMethod])
  @@index([createdAt])
}

model GeneratedCaption {
  id           String      @id @default(cuid())
  movieLogId   String
  tone         CaptionTone
  captionText  String
  hashtagsText String?
  versionNo    Int
  createdAt    DateTime    @default(now())
  movieLog     MovieLog    @relation(fields: [movieLogId], references: [id], onDelete: Cascade)

  @@unique([movieLogId, versionNo, tone])
  @@index([movieLogId, createdAt(sort: Desc)])
  @@index([tone])
}
